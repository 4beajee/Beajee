# Beajee backend — Telegram DEV bot (local testing only)
# Copy to .env.telegram.dev and fill in values. Never commit .env.telegram.dev.

# Dev bot token from @BotFather (NOT the production bot)
TELEGRAM_BOT_TOKEN=""

# Your private chat id with the dev bot (npm run telegram:dev -- resolve-chat-id)
TELEGRAM_CHAT_ID=""

# Optional but recommended — npm run telegram:dev -- gen-secret
TELEGRAM_WEBHOOK_SECRET=""

# Local Next.js URL — poll forwards here; web onboarding stays on localhost
TELEGRAM_DEV_APP_URL="http://localhost:3001"

# Public HTTPS Mini App URL (ngrok/cloudflared) — required for in-Telegram WebView
# TELEGRAM_MINI_APP_URL="https://your-subdomain.ngrok-free.app/telegram"

# Only needed for webhook mode with ngrok/cloudflared:
# TELEGRAM_DEV_APP_URL="https://your-subdomain.ngrok-free.app"